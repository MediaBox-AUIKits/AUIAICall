<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_rounded_setting_dialog">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginHorizontal="20dp">
        
        <TextView
            android:id="@+id/tv_debug_dialog_title"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            style="@style/text_style_16"
            android:text="调试设置"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <ImageView
            android:id="@+id/iv_close_debug_setting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_aicall_close"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:id="@+id/debug_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="20dp">

            <EditText
                android:id="@+id/et_debug_send_custom_message_to_server"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="请输入自定义消息"
                android:textColor="@color/layout_base_red"
                android:textColorHint="@color/layout_base_red"
                android:textSize="14sp"
                android:padding="12dp"
                android:minHeight="48dp"
                android:background="@drawable/bg_reporting_type_selector"
                android:inputType="text"/>

            <TextView
                android:id="@+id/debug_send_custom_message_to_server"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/text_style_14"
                android:text="发送自定义消息到AppServer"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:background="@drawable/bg_reporting_type_selector"/>

            <EditText
                android:id="@+id/et_debug_update_llm_prompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="输入更新LLM提示词"
                android:textColor="@color/layout_base_red"
                android:textColorHint="@color/layout_base_red"
                android:textSize="14sp"
                android:padding="12dp"
                android:minHeight="48dp"
                android:background="@drawable/bg_reporting_type_selector"
                android:inputType="text"/>

            <TextView
                android:id="@+id/debug_update_llm_prompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/text_style_14"
                android:text="更新LLM提示词"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:background="@drawable/bg_reporting_type_selector"/>

            <EditText
                android:id="@+id/et_debug_update_custom_capture"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="输入截帧送检文本"
                android:textColor="@color/layout_base_red"
                android:textColorHint="@color/layout_base_red"
                android:textSize="14sp"
                android:padding="12dp"
                android:minHeight="48dp"
                android:background="@drawable/bg_reporting_type_selector"
                android:inputType="text"/>

            <TextView
                android:id="@+id/debug_send_single_custom_capture"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/text_style_14"
                android:text="开启单次截帧送检"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:background="@drawable/bg_reporting_type_selector"/>

            <TextView
                android:id="@+id/debug_send_continus_custom_capture"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/text_style_14"
                android:text="关闭人声开启持续100s截帧送检"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:background="@drawable/bg_reporting_type_selector"/>

            <TextView
                android:id="@+id/debug_send_continus_custom_capture_enable_asr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/text_style_14"
                android:text="开启人声开启持续100s截帧送检"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:background="@drawable/bg_reporting_type_selector"/>

            <TextView
                android:id="@+id/debug_stop_custom_capture"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/text_style_14"
                android:text="退出自定义截帧送检"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:background="@drawable/bg_reporting_type_selector"/>

            <TextView
                android:id="@+id/debug_mute_agent_audio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/text_style_14"
                android:text="关闭智能体语音"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:background="@drawable/bg_reporting_type_selector"/>

            <TextView
                android:id="@+id/debug_unmute_agent_audio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/text_style_14"
                android:text="打开智能体语音"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:background="@drawable/bg_reporting_type_selector"/>

            <TextView
                android:id="@+id/debug_send_text_to_agent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/text_style_14"
                android:text="SendAIAgentText"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:background="@drawable/bg_reporting_type_selector"/>

            <EditText
                android:id="@+id/et_debug_vcr_update"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="VCR 配置"
                android:textColor="@color/layout_base_red"
                android:textColorHint="@color/layout_base_red"
                android:textSize="14sp"
                android:padding="12dp"
                android:minHeight="48dp"
                android:background="@drawable/bg_reporting_type_selector"
                android:inputType="text"/>

            <TextView
                android:id="@+id/debug_update_vcr_config"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/text_style_14"
                android:text="UpdateVcrConfig"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:background="@drawable/bg_reporting_type_selector"/>

            <EditText
                android:id="@+id/et_debug_bailian_params_update"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="输入百炼参数"
                android:textColor="@color/layout_base_red"
                android:textColorHint="@color/layout_base_red"
                android:textSize="14sp"
                android:padding="12dp"
                android:minHeight="48dp"
                android:background="@drawable/bg_reporting_type_selector"
                android:inputType="text"/>

            <TextView
                android:id="@+id/debug_update_update_bailian_params"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/text_style_14"
                android:text="更新百炼参数"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:background="@drawable/bg_reporting_type_selector"/>

            <EditText
                android:id="@+id/et_debug_tts_speed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="输入智能体播报语速"
                android:textColor="@color/layout_base_red"
                android:textColorHint="@color/layout_base_red"
                android:textSize="14sp"
                android:padding="12dp"
                android:minHeight="48dp"
                android:background="@drawable/bg_reporting_type_selector"
                android:inputType="numberDecimal"/>

            <TextView
                android:id="@+id/debug_update_tts_speed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/text_style_14"
                android:text="更新智能体播报语速"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:background="@drawable/bg_reporting_type_selector"/>

            <EditText
                android:id="@+id/et_debug_asr_max_silence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="输入ASR最大静默时长"
                android:textColor="@color/layout_base_red"
                android:textColorHint="@color/layout_base_red"
                android:textSize="14sp"
                android:padding="12dp"
                android:minHeight="48dp"
                android:background="@drawable/bg_reporting_type_selector"
                android:inputType="number"/>

            <TextView
                android:id="@+id/debug_update_asr_max_silence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/text_style_14"
                android:text="更新ASR最大静默时长"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:background="@drawable/bg_reporting_type_selector"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>